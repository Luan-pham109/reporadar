---
import { INDUSTRIES } from '../lib/industries';

interface Props {
  /** Active industry slug. */
  active?: string;
  /** Show maturity shortcuts on list pages. */
  showHot?: boolean;
}

const { active, showHot = false } = Astro.props;
---

<nav class="flex flex-wrap gap-2 text-sm" aria-label="Industry navigation">
  {showHot && (
    <>
      <a
        href="/#radar"
        class="rounded-md border border-[var(--rr-core)]/40 bg-[var(--rr-core)]/10 px-3 py-1.5 font-semibold text-[var(--rr-core)] no-underline hover:bg-[var(--rr-core)]/15"
      >
        Pre-viral signals
      </a>
      <a
        href="/#radar"
        class="rounded-md border border-[var(--rr-border)] bg-white px-3 py-1.5 font-medium text-[var(--rr-muted)] no-underline hover:border-[var(--rr-core)]/50 hover:text-[var(--rr-text)]"
      >
        Established tools
      </a>
    </>
  )}
  {INDUSTRIES.map((ind) => (
    <a
      href={`/nganh/${ind.slug}`}
      class:list={[
        'rounded-md border px-3 py-1.5 font-medium no-underline transition-colors',
        active === ind.slug
          ? 'border-[var(--rr-core)]/50 bg-[var(--rr-core)]/10 text-[var(--rr-core)]'
          : 'border-[var(--rr-border)] bg-white text-[var(--rr-muted)] hover:border-[var(--rr-core)]/50 hover:text-[var(--rr-text)]',
      ]}
    >
      {ind.short}
    </a>
  ))}
</nav>
