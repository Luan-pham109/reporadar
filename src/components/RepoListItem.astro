---
import type { CollectionEntry } from 'astro:content';
import SignalBadge from './SignalBadge.astro';
import { industryShort } from '../lib/industries';

interface Props {
  entry: CollectionEntry<'repos'>;
}

const { entry } = Astro.props;
const r = entry.data;

const dateStr = r.publishedAt.toLocaleDateString('vi-VN', {
  day: '2-digit',
  month: '2-digit',
});

const greyTone = r.greyHatFlag === 'out' ? 'danger' : r.greyHatFlag === 'borderline' ? 'warn' : null;
const thumb = r.media.find((m) => m.type === 'image');
const primaryVertical = r.vertical[0] ? industryShort(r.vertical[0]) : null;
const secondaryVerticals = r.vertical.slice(1).map((v) => industryShort(v));
const stars = r.repoStats?.stars;
const filterTags = r.tags.map((tag) => tag.toLowerCase()).join('|');
---

<article class="group rounded-lg as-card transition-colors" data-filter-tags={filterTags}>
  <a
    href={`/repos/${entry.id}`}
    class="grid gap-4 p-4 no-underline sm:grid-cols-[112px_1fr_auto] sm:items-start"
    data-track-event="repo_brief_open"
    data-track-label="repo_list_item"
    data-track-prop-surface="repo_list"
    data-track-prop-repo-slug={entry.id}
    data-track-prop-repo-name={r.name}
  >
    {thumb ? (
      <img
        src={thumb.url}
        alt={thumb.caption ?? r.name}
        loading="lazy"
        class="hidden aspect-[4/3] h-20 w-28 rounded-md border border-[var(--rr-border)] object-cover sm:block"
      />
    ) : (
      <div class="hidden h-20 w-28 rounded-md border border-[var(--rr-border)] bg-[var(--rr-surface-soft)] as-grid-bg sm:block"></div>
    )}

    <div class="min-w-0">
      <div class="mb-2 flex flex-wrap items-center gap-1.5">
        {r.maturity === 'pre-viral' && (
          <SignalBadge tone="core" label="Pre-viral Signal" title="Có tín hiệu sớm, đáng theo dõi trước khi mainstream" />
        )}
        {r.maturity === 'rising' && <SignalBadge tone="core" label="Rising" />}
        {r.maturity === 'established' && (
          <SignalBadge tone="muted" label="Established" title="Đã có cộng đồng dùng và đủ dữ liệu để đánh giá thực tế" />
        )}
        {primaryVertical && (
          <span class="rounded-full border border-[var(--rr-border)] bg-[var(--rr-surface-soft)] px-2.5 py-0.5 text-xs font-medium text-[var(--rr-muted)]">
            {primaryVertical}{secondaryVerticals.length > 0 ? ` +${secondaryVerticals.length}` : ''}
          </span>
        )}
        {greyTone && (
          <SignalBadge tone={greyTone} label={r.greyHatFlag === 'out' ? 'High risk' : 'Context needed'} title="Có yếu tố nhạy cảm; cần đọc kỹ trước khi áp dụng" />
        )}
      </div>

      <h3 class="truncate text-lg font-semibold group-hover:text-[var(--rr-core)]">{r.name}</h3>
      <p class="mt-1 line-clamp-2 text-sm leading-5 text-[var(--rr-muted)]">{r.oneLiner}</p>

      <div class="mt-3 grid gap-2 text-xs text-[var(--rr-muted)] sm:grid-cols-2">
        {r.paidToolReplaced && (
          <p class="rounded-md bg-[var(--rr-surface-soft)] px-2.5 py-2">
            <span class="font-semibold text-[var(--rr-text)]">Replaces:</span> {r.paidToolReplaced}
          </p>
        )}
        {r.workflowStepReplaced && (
          <p class="rounded-md bg-[var(--rr-surface-soft)] px-2.5 py-2">
            <span class="font-semibold text-[var(--rr-text)]">Workflow:</span> {r.workflowStepReplaced}
          </p>
        )}
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-2 text-xs text-[var(--rr-muted)] sm:min-w-[112px] sm:justify-end">
      {stars != null && <span>{stars.toLocaleString('vi-VN')} stars</span>}
      <span>{dateStr}</span>
      <span class="font-semibold text-[var(--rr-core)]">Read brief</span>
    </div>
  </a>
</article>
