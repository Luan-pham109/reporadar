---
import type { CollectionEntry } from 'astro:content';
import SignalBadge from './SignalBadge.astro';
import { industryShort } from '../lib/industries';

interface Props {
  entry: CollectionEntry<'repos'>;
}

const { entry } = Astro.props;
const r = entry.data;

const dateStr = r.publishedAt.toLocaleDateString('vi-VN', {
  day: '2-digit',
  month: '2-digit',
});

const greyTone = r.greyHatFlag === 'out' ? 'danger' : r.greyHatFlag === 'borderline' ? 'warn' : null;
const thumb = r.media.find((m) => m.type === 'image');
const primaryVertical = r.vertical[0] ? industryShort(r.vertical[0]) : null;
const secondaryVerticals = r.vertical.slice(1).map((v) => industryShort(v));
const stars = r.repoStats?.stars;
---

<article class="group rounded-md border border-[var(--rr-border)] bg-[var(--rr-surface)] transition-colors hover:border-[var(--rr-core)]/50">
  <a href={`/repos/${entry.id}`} class="grid gap-3 p-3 no-underline sm:grid-cols-[88px_1fr_auto] sm:items-start">
    {thumb ? (
      <img
        src={thumb.url}
        alt={thumb.caption ?? r.name}
        loading="lazy"
        class="hidden aspect-[4/3] h-16 w-[88px] rounded border border-[var(--rr-border)] object-cover sm:block"
      />
    ) : (
      <div class="hidden h-16 w-[88px] rounded border border-[var(--rr-border)] bg-[var(--rr-bg)] sm:block"></div>
    )}

    <div class="min-w-0">
      <div class="mb-1 flex flex-wrap items-center gap-1.5">
        {r.maturity === 'pre-viral' && (
          <SignalBadge tone="core" label="Đáng thử sớm" title="Có tín hiệu tốt, còn ít người Việt khai thác" />
        )}
        {r.maturity === 'established' && (
          <SignalBadge tone="muted" label="Đã có chỗ đứng" title="Công cụ đã có cộng đồng dùng và đủ dữ liệu để đánh giá thực tế" />
        )}
        {greyTone && (
          <SignalBadge tone={greyTone} label={r.greyHatFlag === 'out' ? 'Rủi ro cao' : 'Cần đúng ngữ cảnh'} title="Có yếu tố nhạy cảm; cần đọc kỹ trước khi áp dụng" />
        )}
        {primaryVertical && (
          <span class="rounded-full border border-[var(--rr-border)] px-2 py-0.5 text-[11px] text-[var(--rr-muted)]">
            {primaryVertical}{secondaryVerticals.length > 0 ? ` +${secondaryVerticals.length}` : ''}
          </span>
        )}
      </div>

      <h3 class="truncate text-base font-semibold group-hover:text-[var(--rr-core)]">{r.name}</h3>
      <p class="mt-1 line-clamp-2 text-sm leading-5 text-[var(--rr-muted)]">{r.oneLiner}</p>
      {r.workflowStepReplaced && (
        <p class="mt-2 line-clamp-1 text-xs text-[var(--rr-muted)]">
          <span class="font-medium text-[var(--rr-text)]">Giúp bớt việc:</span> {r.workflowStepReplaced}
        </p>
      )}
    </div>

    <div class="flex flex-wrap items-center gap-2 text-xs text-[var(--rr-muted)] sm:min-w-[94px] sm:justify-end">
      {stars != null && <span>⭐ {stars.toLocaleString('vi-VN')}</span>}
      <span>{dateStr}</span>
      <span class="text-[var(--rr-core)]">Đọc →</span>
    </div>
  </a>
</article>
