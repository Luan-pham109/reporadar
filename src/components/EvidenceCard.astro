---
import type { CollectionEntry } from 'astro:content';
import { computeScore } from '../lib/score';

interface Props {
  data: CollectionEntry<'repos'>['data'];
}

const { data } = Astro.props;
const { total, hasScore, breakdown } = computeScore(data);

const evLevelLabel: Record<string, string> = {
  A: 'A — Lab tested',
  B: 'B — Signal reviewed',
  C: 'C — Discovery',
  D: 'D — Unverified',
};
const confLabel: Record<string, string> = {
  high: 'High confidence',
  medium: 'Medium confidence',
  low: 'Low confidence',
};
const evLevelColor: Record<string, string> = {
  A: 'text-green-700 border-green-500/30 bg-green-50',
  B: 'text-[var(--rr-core)] border-[var(--rr-core)]/30 bg-[var(--rr-core)]/8',
  C: 'text-amber-700 border-amber-400/30 bg-amber-50',
  D: 'text-[var(--rr-muted)] border-[var(--rr-border)] bg-white',
};
const confColor: Record<string, string> = {
  high: 'text-green-700 border-green-500/30 bg-green-50',
  medium: 'text-amber-700 border-amber-400/30 bg-amber-50',
  low: 'text-[var(--rr-muted)] border-[var(--rr-border)] bg-white',
};

const reviewedStr = data.lastReviewedAt
  ? data.lastReviewedAt.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' })
  : null;

const hasMetadata = data.evidenceLevel || data.confidence || reviewedStr;
const hasSources = data.signalSources && data.signalSources.length > 0;
---

<aside class="rounded-lg border border-[var(--rr-border)] bg-white overflow-hidden">
  <!-- Header -->
  <div class="flex items-center justify-between gap-3 px-5 py-3 border-b border-[var(--rr-border)] bg-[var(--rr-surface-soft)]">
    <p class="text-xs font-bold uppercase tracking-widest text-[var(--rr-muted)]">Signal Score · v1</p>
    <a
      href="/methodology"
      class="text-xs font-medium text-[var(--rr-core)] no-underline hover:underline"
    >
      Cách tính điểm →
    </a>
  </div>

  <div class="p-5 space-y-5">
    {hasScore ? (
      <>
        <!-- Score total -->
        <div class="flex items-baseline gap-2">
          <span class="text-5xl font-bold leading-none text-[var(--rr-dark)]">{total}</span>
          <span class="text-lg font-medium text-[var(--rr-muted)]">/100</span>
        </div>

        <!-- Breakdown bars -->
        <div class="space-y-2.5">
          {breakdown.map(({ key, label, value, max, kind }) => {
            const pct = max > 0 ? Math.round((value / max) * 100) : 0;
            return (
              <div>
                <div class="flex items-center justify-between gap-2 mb-1">
                  <span class="text-xs font-semibold text-[var(--rr-text)]">{label}</span>
                  <div class="flex items-center gap-1.5">
                    <span class="text-xs text-[var(--rr-muted)]">{value}/{max}</span>
                    <span
                      class:list={[
                        'rounded-sm px-1.5 py-0.5 text-[10px] font-bold uppercase',
                        kind === 'auto'
                          ? 'bg-blue-100 text-blue-700'
                          : 'bg-[var(--rr-surface-soft)] text-[var(--rr-faint)] border border-[var(--rr-border)]',
                      ]}
                    >
                      {kind === 'auto' ? 'auto' : 'judged'}
                    </span>
                  </div>
                </div>
                <div class="h-1.5 w-full rounded-full bg-[var(--rr-surface-soft)]">
                  <div
                    class="h-1.5 rounded-full bg-[var(--rr-core)]"
                    style={`width:${pct}%`}
                  />
                </div>
              </div>
            );
          })}
        </div>
      </>
    ) : (
      <p class="text-sm text-[var(--rr-muted)]">Chưa có điểm — sẽ cập nhật sau khi review.</p>
    )}

    <!-- Evidence metadata -->
    {hasMetadata && (
      <div class="flex flex-wrap items-center gap-2 pt-1 border-t border-[var(--rr-border)]">
        {data.evidenceLevel && (
          <span class:list={[
            'inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold',
            evLevelColor[data.evidenceLevel] ?? evLevelColor['C'],
          ]}>
            {evLevelLabel[data.evidenceLevel] ?? data.evidenceLevel}
          </span>
        )}
        {data.confidence && (
          <span class:list={[
            'inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold',
            confColor[data.confidence] ?? confColor['low'],
          ]}>
            {confLabel[data.confidence] ?? data.confidence}
          </span>
        )}
        {reviewedStr && (
          <span class="text-xs text-[var(--rr-faint)]">Reviewed {reviewedStr}</span>
        )}
      </div>
    )}

    <!-- Signal sources (public) -->
    {hasSources && (
      <div class="pt-1 border-t border-[var(--rr-border)]">
        <p class="text-xs font-bold uppercase tracking-widest text-[var(--rr-muted)] mb-2">Nguồn tín hiệu</p>
        <div class="flex flex-wrap gap-1.5">
          {data.signalSources.map((s) => (
            <a
              href={s.url}
              target="_blank"
              rel="nofollow noopener noreferrer"
              class="rounded border border-[var(--rr-border)] px-2.5 py-1 text-xs font-medium text-[var(--rr-muted)] no-underline hover:border-[var(--rr-core)]/50 hover:text-[var(--rr-text)]"
            >
              {s.label} ↗
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Known limitations -->
    {data.usabilityRisk && (
      <div class="rounded-md border border-amber-300/25 bg-amber-50 p-3">
        <p class="text-xs font-bold uppercase text-amber-700 mb-1">Lưu ý triển khai</p>
        <p class="text-xs leading-5 text-amber-800">{data.usabilityRisk}</p>
      </div>
    )}
  </div>
</aside>
