---
import type { CollectionEntry } from 'astro:content';
import SignalBadge from './SignalBadge.astro';
import { industryShort } from '../lib/industries';

interface Props {
  entry: CollectionEntry<'repos'>;
}

const { entry } = Astro.props;
const r = entry.data;

const dateStr = r.publishedAt.toLocaleDateString('vi-VN', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric',
});

// Cảnh báo grey-hat (kỷ luật IN/OUT).
const greyTone = r.greyHatFlag === 'out' ? 'danger' : r.greyHatFlag === 'borderline' ? 'warn' : null;
// Thumbnail = ảnh đầu tiên trong media (nếu có) — cho feed dễ quét.
const thumb = r.media.find((m) => m.type === 'image');
---

<article class="overflow-hidden rounded-lg border border-[var(--rr-border)] bg-[var(--rr-surface)] transition-colors hover:border-[var(--rr-core)]/50">
  {thumb && (
    <a href={`/repos/${entry.id}`} class="block">
      <img
        src={thumb.url}
        alt={thumb.caption ?? r.name}
        loading="lazy"
        class="aspect-[2/1] w-full border-b border-[var(--rr-border)] object-cover"
      />
    </a>
  )}
  <div class="p-5">
  <div class="mb-2 flex flex-wrap items-center gap-2">
    {r.maturity === 'pre-viral' && (
      <SignalBadge tone="core" label="⚡ Đáng thử sớm" title="Có tín hiệu tốt từ cộng đồng quốc tế, nhưng ở Việt Nam còn ít người khai thác" />
    )}
    {r.maturity === 'established' && (
      <SignalBadge tone="muted" label="⭐ Đã có chỗ đứng" title="Công cụ đã có cộng đồng dùng và đủ dữ liệu để đánh giá thực tế" />
    )}
    {r.vertical.map((v) => (
      <a
        href={`/nganh/${v}`}
        class="rounded-full border border-[var(--rr-border)] px-2.5 py-0.5 text-xs text-[var(--rr-muted)] no-underline hover:border-[var(--rr-core)]/50 hover:text-[var(--rr-text)]"
      >
        {industryShort(v)}
      </a>
    ))}
    {greyTone && (
      <SignalBadge tone={greyTone} label={r.greyHatFlag === 'out' ? '⚠ Rủi ro cao' : 'Cần kể đúng ngữ cảnh'} title="Có yếu tố nhạy cảm; cần đọc kỹ trước khi áp dụng" />
    )}
    {r.aiCheck.canAIGetThis && (
      <SignalBadge tone="warn" label="Cần đào sâu thêm" title="Thông tin cơ bản đã dễ tìm; giá trị nằm ở cách áp dụng thực tế" />
    )}
    <span class="ml-auto text-xs text-[var(--rr-muted)]">{dateStr} · {r.week}</span>
  </div>

  <h2 class="text-xl font-semibold">
    <a href={`/repos/${entry.id}`} class="no-underline hover:text-[var(--rr-core)]">{r.name}</a>
  </h2>

  <p class="mt-1 text-sm text-[var(--rr-muted)]">{r.oneLiner}</p>

  {r.repoStats && (r.repoStats.stars != null || r.repoStats.forks != null) && (
    <p class="mt-2 flex gap-3 text-xs text-[var(--rr-muted)]">
      {r.repoStats.stars != null && <span>⭐ {r.repoStats.stars.toLocaleString('vi-VN')}</span>}
      {r.repoStats.forks != null && <span>🍴 {r.repoStats.forks.toLocaleString('vi-VN')}</span>}
    </p>
  )}

  <div class="mt-3 rounded-md border border-[var(--rr-border)] bg-[var(--rr-bg)] p-3">
    <p class="text-xs font-semibold uppercase tracking-wide text-[var(--rr-core)]">Bài toán ở Việt Nam</p>
    <p class="mt-1 text-sm">{r.localProblem}</p>
    {r.workflowStepReplaced && (
      <p class="mt-2 text-xs text-[var(--rr-muted)]"><span class="font-medium text-[var(--rr-text)]">Giúp bớt việc:</span> {r.workflowStepReplaced}</p>
    )}
  </div>

  {r.tags.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-1.5">
      {r.tags.map((t) => (
        <span class="rounded bg-[var(--rr-bg)] px-2 py-0.5 text-xs text-[var(--rr-muted)]">#{t}</span>
      ))}
    </div>
  )}
  </div>
</article>
