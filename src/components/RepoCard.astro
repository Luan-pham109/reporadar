---
import type { CollectionEntry } from 'astro:content';
import SignalBadge from './SignalBadge.astro';
import { industryShort } from '../lib/industries';
import { computeScore } from '../lib/score';

interface Props {
  entry: CollectionEntry<'repos'>;
}

const { entry } = Astro.props;
const r = entry.data;

const dateStr = r.publishedAt.toLocaleDateString('vi-VN', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric',
});

const greyTone = r.greyHatFlag === 'out' ? 'danger' : r.greyHatFlag === 'borderline' ? 'warn' : null;
const thumb = r.media.find((m) => m.type === 'image');
const signalColor =
  greyTone === 'danger'
    ? 'bg-[var(--rr-danger)]'
    : greyTone === 'warn'
      ? 'bg-[var(--rr-warn)]'
      : r.maturity === 'established'
        ? 'bg-[var(--rr-border-strong)]'
        : 'bg-[var(--rr-core)]';
const filterTags = r.tags.map((tag) => tag.toLowerCase()).join('|');
const { total, hasScore } = computeScore(r);
---

<article class="group overflow-hidden rounded-lg as-card transition-colors" data-filter-tags={filterTags}>
  <div class:list={['h-1.5 w-full', signalColor]}></div>
  {thumb && (
    <a href={`/repos/${entry.id}`} class="block bg-[var(--rr-surface-soft)]">
      <img
        src={thumb.url}
        alt={thumb.caption ?? r.name}
        loading="lazy"
        class="aspect-[3.2/1] w-full border-b border-[var(--rr-border)] object-cover"
      />
    </a>
  )}

  <div class="p-5">
    <div class="mb-3 flex flex-wrap items-center gap-2">
      {r.maturity === 'pre-viral' && (
        <SignalBadge tone="core" label="Pre-viral Signal" title="Có tín hiệu sớm, đáng theo dõi trước khi mainstream" />
      )}
      {r.maturity === 'rising' && <SignalBadge tone="core" label="Rising" />}
      {r.maturity === 'established' && (
        <SignalBadge tone="muted" label="Established" title="Đã có cộng đồng dùng và đủ dữ liệu để đánh giá thực tế" />
      )}
      {r.vertical.map((v) => (
        <a
          href={`/nganh/${v}`}
          class="rounded-full border border-[var(--rr-border)] bg-[var(--rr-surface-soft)] px-2.5 py-0.5 text-xs font-medium text-[var(--rr-muted)] no-underline hover:border-[var(--rr-core)]/50 hover:text-[var(--rr-text)]"
        >
          {industryShort(v)}
        </a>
      ))}
      {greyTone && (
        <SignalBadge tone={greyTone} label={r.greyHatFlag === 'out' ? 'High risk' : 'Context needed'} title="Có yếu tố nhạy cảm; cần đọc kỹ trước khi áp dụng" />
      )}
      {r.aiCheck.canAIGetThis && (
        <SignalBadge tone="warn" label="Needs testing" title="Thông tin cơ bản dễ tìm; giá trị nằm ở cách áp dụng thực tế" />
      )}
      {r.evidenceLevel && (
        <span class="rounded-full border border-[var(--rr-border)] bg-[var(--rr-surface-soft)] px-2.5 py-0.5 text-xs font-medium text-[var(--rr-muted)]" title="Evidence Level — A: lab-tested · B: signal-reviewed · C: discovery · D: unverified">
          Ev.{r.evidenceLevel}
        </span>
      )}
      {hasScore && (
        <span class="rounded-full border border-[var(--rr-core)]/40 bg-[var(--rr-core)]/8 px-2.5 py-0.5 text-xs font-bold text-[var(--rr-core)]" title="Signal Score v1 — xem methodology để hiểu cách tính">
          {total}/100
        </span>
      )}
      <span class="ml-auto text-xs text-[var(--rr-faint)]">{dateStr} · {r.week}</span>
    </div>

    <h2 class="text-xl font-semibold leading-tight">
      <a href={`/repos/${entry.id}`} class="no-underline hover:text-[var(--rr-core)]">{r.name}</a>
    </h2>

    <p class="mt-1 text-sm leading-6 text-[var(--rr-muted)]">{r.oneLiner}</p>

    {r.repoStats && (r.repoStats.stars != null || r.repoStats.forks != null) && (
      <p class="mt-3 flex gap-3 text-xs font-medium text-[var(--rr-faint)]">
        {r.repoStats.stars != null && <span>{r.repoStats.stars.toLocaleString('vi-VN')} stars</span>}
        {r.repoStats.forks != null && <span>{r.repoStats.forks.toLocaleString('vi-VN')} forks</span>}
      </p>
    )}

    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      {r.paidToolReplaced && (
        <div class="rounded-md border border-[var(--rr-open)]/25 bg-[var(--rr-open)]/10 p-3">
          <p class="text-xs font-bold uppercase text-green-700">Replaces</p>
          <p class="mt-1 text-sm font-medium">{r.paidToolReplaced}</p>
        </div>
      )}
      {(r.workflowStepReplaced || r.timeOrCostSaved) && (
        <div class="rounded-md border border-[var(--rr-border)] bg-[var(--rr-surface-soft)] p-3">
          <p class="text-xs font-bold uppercase text-[var(--rr-muted)]">Workflow impact</p>
          <p class="mt-1 text-sm font-medium">{r.workflowStepReplaced || r.timeOrCostSaved}</p>
        </div>
      )}
    </div>

    <div class="mt-4 rounded-md border border-[var(--rr-core)]/25 bg-[var(--rr-core)]/5 p-3">
      <p class="text-xs font-semibold uppercase text-[var(--rr-core)]">VN fit question</p>
      <p class="mt-1 text-sm leading-6">{r.localProblem}</p>
    </div>

    {r.tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-1.5">
        {r.tags.slice(0, 6).map((t) => (
          <a href={`/?tag=${encodeURIComponent(t)}#radar`} class="rounded bg-[var(--rr-surface-soft)] px-2 py-0.5 text-xs font-medium text-[var(--rr-muted)] no-underline hover:text-[var(--rr-core)]">#{t}</a>
        ))}
      </div>
    )}

    <a
      href={`/repos/${entry.id}`}
      class="mt-5 flex items-center justify-between rounded-md bg-[var(--rr-dark)] px-3 py-2.5 text-sm font-semibold !text-white no-underline transition-colors group-hover:bg-[var(--rr-core)]"
      data-track-event="repo_brief_open"
      data-track-label="repo_card_open_decision_brief"
      data-track-prop-surface="repo_card"
      data-track-prop-repo-slug={entry.id}
      data-track-prop-repo-name={r.name}
    >
      <span>Open decision brief</span>
      <span aria-hidden="true">→</span>
    </a>
  </div>
</article>
