---
type Tone = 'core' | 'open' | 'warn' | 'danger' | 'muted';

interface Props {
  tone?: Tone;
  label: string;
  title?: string;
}

const { tone = 'muted', label, title } = Astro.props;

const toneStyles: Record<Tone, string> = {
  core: 'text-[var(--rr-core)] border-[var(--rr-core)]/35 bg-[var(--rr-core)]/10',
  open: 'text-green-700 border-[var(--rr-open)]/35 bg-[var(--rr-open)]/10',
  warn: 'text-amber-700 border-[var(--rr-warn)]/35 bg-[var(--rr-warn)]/10',
  danger: 'text-red-700 border-[var(--rr-danger)]/35 bg-[var(--rr-danger)]/10',
  muted: 'text-[var(--rr-muted)] border-[var(--rr-border)] bg-white',
};
---

<span
  class:list={[
    'inline-flex items-center gap-1 rounded-full border px-2.5 py-0.5 text-xs font-semibold',
    toneStyles[tone],
  ]}
  title={title}
>
  {label}
</span>
