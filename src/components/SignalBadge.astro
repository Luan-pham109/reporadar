---
// Badge nhỏ cho các tín hiệu vùng-AI-mù. Cố tình KHÔNG có badge "trending"
// — định vị là pre-viral + local, không phải bảng xếp hạng (PRD §1.3).
type Tone = 'core' | 'warn' | 'danger' | 'muted';

interface Props {
  tone?: Tone;
  label: string;
  title?: string;
}

const { tone = 'muted', label, title } = Astro.props;

const toneStyles: Record<Tone, string> = {
  core: 'text-[var(--rr-core)] border-[var(--rr-core)]/40 bg-[var(--rr-core)]/10',
  warn: 'text-[var(--rr-warn)] border-[var(--rr-warn)]/40 bg-[var(--rr-warn)]/10',
  danger: 'text-[var(--rr-danger)] border-[var(--rr-danger)]/40 bg-[var(--rr-danger)]/10',
  muted: 'text-[var(--rr-muted)] border-[var(--rr-border)] bg-transparent',
};
---

<span
  class:list={[
    'inline-flex items-center gap-1 rounded-full border px-2.5 py-0.5 text-xs font-medium',
    toneStyles[tone],
  ]}
  title={title}
>
  {label}
</span>
