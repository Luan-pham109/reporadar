---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RepoListItem from '../../components/RepoListItem.astro';
import EvidenceCard from '../../components/EvidenceCard.astro';
import { industryShort } from '../../lib/industries';
import { includeDraft, shouldShowDrafts } from '../../lib/drafts';
import { pageTitle } from '../../lib/seo';

export async function getStaticPaths() {
  const all = await getCollection('repos');
  const entries = all.filter((e) => includeDraft(e.data));
  const linkable = entries;

  return entries.map((entry) => {
    const related = linkable
      .filter((e) => e.id !== entry.id)
      .map((e) => {
        const sharedV = e.data.vertical.filter((v) => entry.data.vertical.includes(v)).length;
        const sharedT = e.data.tags.filter((t) => entry.data.tags.includes(t)).length;
        return { e, score: sharedV * 2 + sharedT };
      })
      .filter((x) => x.score > 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, 4)
      .map((x) => x.e);

    return { params: { slug: entry.id }, props: { entry, related } };
  });
}

const { entry, related } = Astro.props;
const r = entry.data;
const { Content } = await render(entry);
const showInternalAnalysis = shouldShowDrafts && ['localhost', '127.0.0.1'].includes(Astro.url.hostname);
const guide = r.practitionerGuide;
const hasPractitionerGuide =
  Boolean(guide.outcome) ||
  guide.prerequisites.length > 0 ||
  guide.steps.length > 0 ||
  Boolean(guide.expectedResult) ||
  guide.commonPitfalls.length > 0;

const dateStr = r.publishedAt.toLocaleDateString('vi-VN', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric',
});
const greyTone = r.greyHatFlag === 'out' ? 'danger' : r.greyHatFlag === 'borderline' ? 'warn' : null;
const heroImg = r.media.find((m) => m.type === 'image')?.url;
const keywords = [...r.vnMarket.seoKeywords, ...r.tags].join(', ');
const seoTitle = pageTitle(`${r.name} – giải pháp open-source`);
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const repoLoginUrl = `/login?returnTo=${encodeURIComponent(Astro.url.pathname)}`;
const repoSlug = entry.id;
const repoOutboundUrl = withUtmSource(r.repoUrl);
const savedRepoStatuses = [
  { value: 'want_to_try', label: 'Muốn thử' },
  { value: 'testing', label: 'Đang test' },
  { value: 'watching', label: 'Theo dõi' },
  { value: 'skipped', label: 'Bỏ qua' },
  { value: 'using', label: 'Đã dùng' },
];

function withUtmSource(url: string) {
  try {
    const next = new URL(url);
    if (!next.searchParams.has('utm_source')) next.searchParams.set('utm_source', 'altstack');
    return next.href;
  } catch {
    return url;
  }
}

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: seoTitle,
  description: r.oneLiner,
  datePublished: r.publishedAt.toISOString(),
  inLanguage: 'vi',
  author: { '@type': 'Organization', name: 'AltStack' },
  publisher: { '@type': 'Organization', name: 'AltStack' },
  mainEntityOfPage: canonical,
  ...(heroImg ? { image: [heroImg] } : {}),
  ...(keywords ? { keywords } : {}),
  about: { '@type': 'SoftwareApplication', name: r.name, applicationCategory: 'BusinessApplication', url: r.repoUrl },
};

const faqs = [
  r.useCases.length > 0 && { q: `${r.name} dùng để làm gì?`, a: r.useCases.join(' ') },
  r.paidToolReplaced && { q: `${r.name} thay được tool trả phí nào?`, a: `${r.name} có thể thay ${r.paidToolReplaced}.` },
  r.usabilityRisk && { q: `Cần lưu ý gì trước khi dùng ${r.name}?`, a: r.usabilityRisk },
].filter(Boolean) as { q: string; a: string }[];

const faqLd =
  faqs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqs.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        })),
      }
    : null;
---

<BaseLayout title={seoTitle} description={r.oneLiner} image={heroImg} keywords={keywords} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
    {faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}
  </Fragment>

  <a href="/" class="text-sm font-medium text-[var(--rr-muted)] no-underline hover:text-[var(--rr-core)]">← AltStack Radar</a>

  <header class="mt-4 overflow-hidden rounded-lg border border-[var(--rr-dark)] bg-[var(--rr-dark)] text-white shadow-[var(--rr-shadow)]">
    <div class="grid lg:grid-cols-[1.1fr_0.9fr]">
      <div class="p-6 sm:p-8">
        <div class="mb-4 flex flex-wrap items-center gap-2">
          {r.maturity === 'pre-viral' && (
            <span class="rounded-full border border-blue-300/25 bg-blue-400/15 px-2.5 py-0.5 text-xs font-bold text-blue-100">Pre-viral Signal</span>
          )}
          {r.maturity === 'rising' && (
            <span class="rounded-full border border-blue-300/25 bg-blue-400/15 px-2.5 py-0.5 text-xs font-bold text-blue-100">Rising</span>
          )}
          {r.maturity === 'established' && (
            <span class="rounded-full border border-white/20 bg-white/10 px-2.5 py-0.5 text-xs font-bold text-white">Established</span>
          )}
          {greyTone && (
            <span class:list={[
              'rounded-full border px-2.5 py-0.5 text-xs font-bold',
              greyTone === 'danger'
                ? 'border-red-300/30 bg-red-400/15 text-red-100'
                : 'border-amber-300/30 bg-amber-400/15 text-amber-100',
            ]}>
              {r.greyHatFlag === 'out' ? 'High risk' : 'Context needed'}
            </span>
          )}
          <span class="text-xs font-medium text-slate-400">{dateStr} · {r.week}</span>
        </div>
        <h1 class="max-w-3xl text-4xl font-bold tracking-tight sm:text-5xl">{r.name}</h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-slate-300">{r.oneLiner}</p>
        <div class="mt-5 grid gap-3">
          <div class="flex flex-wrap gap-2">
            {r.vertical.map((v) => (
              <a href={`/nganh/${v}`} class="rounded-md border border-white/15 bg-white/10 px-3 py-1.5 text-xs font-semibold text-white no-underline hover:bg-white/15">
                {industryShort(v)}
              </a>
            ))}
          </div>

          {r.repoStats && (r.repoStats.stars != null || r.repoStats.forks != null || r.repoStats.note) && (
            <div class="overflow-hidden rounded-lg border border-blue-300/30 bg-blue-400/15 shadow-[0_16px_42px_rgba(37,99,235,0.22)]">
              <div class="flex flex-wrap items-center justify-between gap-3 border-b border-white/15 px-4 py-3">
                <div class="flex items-center gap-2">
                  <span class="grid h-8 w-8 place-items-center rounded-md bg-blue-300 text-sm font-black text-[var(--rr-dark)]">★</span>
                  <div>
                    <p class="text-xs font-bold uppercase tracking-widest text-blue-100">Repo signal</p>
                    <p class="text-xs text-slate-300">GitHub traction để cân nhắc độ đáng thử.</p>
                  </div>
                </div>
              </div>
              <div class="grid gap-0 sm:grid-cols-2">
                {r.repoStats.stars != null && (
                  <div class="border-b border-white/15 p-4 sm:border-b-0 sm:border-r">
                    <p class="font-display text-4xl font-bold leading-none text-white">{r.repoStats.stars.toLocaleString('vi-VN')}</p>
                    <p class="mt-2 flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest text-blue-100">
                      <span class="text-green-300">★</span>
                      Stars
                    </p>
                  </div>
                )}
                {r.repoStats.forks != null && (
                  <div class="p-4">
                    <p class="font-display text-4xl font-bold leading-none text-white">{r.repoStats.forks.toLocaleString('vi-VN')}</p>
                    <p class="mt-2 flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest text-blue-100">
                      <span class="text-amber-300">⑂</span>
                      Forks
                    </p>
                  </div>
                )}
              </div>
              {r.repoStats.note && <p class="border-t border-white/15 px-4 py-3 text-sm leading-6 text-blue-50">{r.repoStats.note}</p>}
            </div>
          )}
        </div>
      </div>

      <div class="border-t border-white/10 bg-white/[0.04] p-6 sm:p-8 lg:border-l lg:border-t-0">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-200">Decision brief</p>
        <div class="mt-4 grid gap-3">
          {r.paidToolReplaced && (
            <div class="rounded-md border border-green-300/20 bg-green-400/10 p-3">
              <p class="text-xs font-bold uppercase text-green-300">Replaces</p>
              <p class="mt-1 text-sm font-semibold">{r.paidToolReplaced}</p>
            </div>
          )}
          {r.workflowStepReplaced && (
            <div class="rounded-md border border-white/10 bg-white/10 p-3">
              <p class="text-xs font-bold uppercase text-slate-400">Workflow cut</p>
              <p class="mt-1 text-sm font-semibold">{r.workflowStepReplaced}</p>
            </div>
          )}
          {r.usabilityRisk && (
            <div class="rounded-md border border-amber-300/20 bg-amber-400/10 p-3">
              <p class="text-xs font-bold uppercase text-amber-300">Caution</p>
              <p class="mt-1 text-sm leading-6 text-slate-100">{r.usabilityRisk}</p>
            </div>
          )}
        </div>
      </div>
    </div>
  </header>

  <div class="mt-6">
    <EvidenceCard data={r} />
  </div>

  <section class="mt-6 grid gap-4 lg:grid-cols-[0.9fr_1.1fr]">
    <div class="rounded-lg border border-[var(--rr-border)] bg-white p-5">
      <p class="text-xs font-bold uppercase tracking-widest text-[var(--rr-muted)]">VN fit</p>
      <p class="mt-2 text-lg font-semibold leading-7">{r.localProblem}</p>
      <p class="mt-3 text-sm leading-6 text-[var(--rr-muted)]">{r.localEvidence}</p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      {r.timeOrCostSaved && (
        <div class="rounded-lg border border-[var(--rr-open)]/25 bg-[var(--rr-open)]/10 p-5">
          <p class="text-xs font-bold uppercase tracking-widest text-green-700">Saved</p>
          <p class="mt-2 text-sm font-semibold leading-6">{r.timeOrCostSaved}</p>
        </div>
      )}
    </div>
  </section>

  {r.media.length > 0 && (
    <section class="mt-8 grid gap-4 lg:grid-cols-2">
      {r.media.map((m) =>
        m.type === 'video' ? (
          <figure class="overflow-hidden rounded-lg border border-[var(--rr-border)] bg-white">
            <video src={m.url} controls preload="metadata" class="w-full bg-black"></video>
            {m.caption && <figcaption class="p-3 text-xs text-[var(--rr-muted)]">{m.caption}</figcaption>}
          </figure>
        ) : (
          <figure class="overflow-hidden rounded-lg border border-[var(--rr-border)] bg-white">
            <img src={m.url} alt={m.caption ?? r.name} loading="lazy" class="w-full" />
            {m.caption && <figcaption class="p-3 text-xs text-[var(--rr-muted)]">{m.caption}</figcaption>}
          </figure>
        ),
      )}
    </section>
  )}

  {r.useCases.length > 0 && (
    <section class="mt-8 rounded-lg border border-[var(--rr-border)] bg-white p-5">
      <p class="text-xs font-bold uppercase tracking-widest text-[var(--rr-core)]">Use cases</p>
      <h2 class="mt-1 text-2xl font-semibold">{r.name} dùng để làm gì?</h2>
      <ul class="mt-4 grid gap-3 sm:grid-cols-2">
        {r.useCases.map((uc) => (
          <li class="rounded-md border border-[var(--rr-border)] bg-[var(--rr-surface-soft)] p-3 text-sm leading-6">{uc}</li>
        ))}
      </ul>
    </section>
  )}

  {r.standoutFeatures.length > 0 && (
    <section class="mt-6 rounded-lg border border-[var(--rr-border)] bg-white p-5">
      <p class="text-xs font-bold uppercase tracking-widest text-[var(--rr-muted)]">Why it stands out</p>
      <ul class="mt-3 grid gap-2">
        {r.standoutFeatures.map((feature) => (
          <li class="border-l-2 border-[var(--rr-core)] pl-3 text-sm leading-6">{feature}</li>
        ))}
      </ul>
    </section>
  )}

  <section class="mt-8 rounded-lg border border-[var(--rr-dark)] bg-[var(--rr-dark)] p-6 text-white">
    <div id="member-lock" class="grid gap-5 sm:grid-cols-[1.2fr_0.8fr] sm:items-start">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-blue-200">Member insight</p>
        <h2 class="mt-2 text-2xl font-semibold">Dùng thử {r.name} theo từng bước</h2>
        <p class="mt-2 text-sm leading-6 text-slate-300">
          Bản public giúp bạn quyết định có nên mở tab hay không. Member area đi thêm một nhịp:
          lưu repo vào shortlist, để note riêng cho lần test tới, rồi mở guide đúng lúc cần chạy thật.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <a
            href={repoLoginUrl}
            class="rounded-md bg-white px-3 py-2 text-sm font-semibold !text-[var(--rr-dark)] no-underline hover:bg-slate-100"
            data-track-event="membership_intent"
            data-track-label="repo_detail_member_guide"
            data-track-prop-surface="repo_detail_member_insight"
            data-track-prop-repo-slug={entry.id}
            data-track-prop-repo-name={r.name}
          >
            Đăng nhập để lưu repo và mở guide
          </a>
          <a
            href={repoOutboundUrl}
            target="_blank"
            rel="nofollow noopener noreferrer"
            class="rounded-md border border-white/30 px-3 py-2 text-sm font-semibold text-white no-underline hover:border-white/50 hover:bg-white/10"
            data-track-event="repo_open"
            data-track-label="repo_detail_member_insight"
            data-track-prop-surface="repo_detail_member_insight"
            data-track-prop-repo-slug={entry.id}
            data-track-prop-repo-name={r.name}
            data-track-prop-repo-url={repoOutboundUrl}
          >
            Mở repo ↗
          </a>
        </div>
      </div>
      <ul class="space-y-2 text-sm">
        <li class="rounded-md border border-white/10 bg-white/10 p-3">
          <span class="font-semibold text-white">Practitioner guide:</span>
          <span class="text-slate-300">
            {hasPractitionerGuide
              ? ` ${guide.steps.length} bước thử nhanh, kèm chuẩn bị và kết quả kỳ vọng.`
              : ' Khung hướng dẫn từng bước để thử tool trong việc thật.'}
          </span>
        </li>
        <li class="rounded-md border border-white/10 bg-white/10 p-3">
          <span class="font-semibold text-white">Shortlist cá nhân:</span>
          <span class="text-slate-300"> Lưu repo vào Muốn thử, Đang test, Theo dõi hoặc Bỏ qua để quay lại đúng lúc.</span>
        </li>
      </ul>
    </div>

    <div id="member-guide" class="hidden">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-green-300">Member insight unlocked</p>
          <h2 id="member-guide-title" class="mt-2 text-2xl font-semibold">Guide thực hành cho {r.name}</h2>
          <p id="member-guide-outcome" class="mt-2 max-w-3xl text-sm leading-6 text-slate-300"></p>
        </div>
        <div class="flex flex-wrap gap-2">
          <a
            href={repoOutboundUrl}
            target="_blank"
            rel="nofollow noopener noreferrer"
            class="rounded-md bg-white px-3 py-2 text-sm font-semibold !text-[var(--rr-dark)] no-underline hover:bg-slate-100"
            data-track-event="repo_open"
            data-track-label="repo_detail_member_guide_unlocked"
            data-track-prop-surface="repo_detail_member_guide"
            data-track-prop-repo-slug={entry.id}
            data-track-prop-repo-name={r.name}
            data-track-prop-repo-url={repoOutboundUrl}
          >
            Mở repo ↗
          </a>
          <a
            href="/account"
            class="rounded-md border border-white/30 px-3 py-2 text-sm font-semibold text-white no-underline hover:border-white/50 hover:bg-white/10"
          >
            Tài khoản
          </a>
        </div>
      </div>

      <div class="mt-5 grid gap-4 lg:grid-cols-[0.8fr_1.2fr]">
        <div class="space-y-4">
          <div class="rounded-md border border-white/10 bg-white/10 p-4">
            <h3 class="text-sm font-semibold text-white">Cần chuẩn bị</h3>
            <ul id="member-guide-prerequisites" class="mt-3 space-y-2 text-sm leading-6 text-slate-300"></ul>
          </div>
          <div class="rounded-md border border-white/10 bg-white/10 p-4">
            <h3 class="text-sm font-semibold text-white">Kết quả đạt</h3>
            <p id="member-guide-expected" class="mt-3 text-sm leading-6 text-slate-300"></p>
          </div>
        </div>

        <div class="space-y-4">
          <div class="rounded-md border border-white/10 bg-white/10 p-4">
            <h3 class="text-sm font-semibold text-white">Các bước thử nhanh</h3>
            <ol id="member-guide-steps" class="mt-3 space-y-3 text-sm leading-6 text-slate-300"></ol>
          </div>
          <div class="rounded-md border border-amber-300/20 bg-amber-400/10 p-4">
            <h3 class="text-sm font-semibold text-amber-100">Bẫy dễ mất thời gian</h3>
            <ul id="member-guide-pitfalls" class="mt-3 space-y-2 text-sm leading-6 text-amber-50"></ul>
          </div>
        </div>
      </div>
    </div>

    <div id="member-save-panel" class="mt-5 rounded-md border border-white/10 bg-white/10 p-4">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-blue-200">Shortlist action</p>
          <h3 class="mt-1 text-lg font-semibold text-white">Lưu repo này vào shortlist của bạn</h3>
          <p id="member-save-status" class="mt-2 text-sm leading-6 text-slate-300" aria-live="polite">
            Đăng nhập để lưu repo, thêm note riêng và quay lại guide khi cần thử thật.
          </p>
        </div>
        <a
          href="/account"
          class="rounded-md border border-white/30 px-3 py-2 text-sm font-semibold text-white no-underline hover:border-white/50 hover:bg-white/10"
        >
          Mở account
        </a>
      </div>

      <div id="member-save-guest" class="mt-4 flex flex-wrap gap-2">
        <a
          href={repoLoginUrl}
          class="rounded-md bg-white px-3 py-2 text-sm font-semibold !text-[var(--rr-dark)] no-underline hover:bg-slate-100"
          data-track-event="membership_intent"
          data-track-label="repo_detail_shortlist_guest"
          data-track-prop-surface="repo_detail_shortlist"
          data-track-prop-repo-slug={entry.id}
          data-track-prop-repo-name={r.name}
        >
          Đăng nhập để lưu repo
        </a>
      </div>

      <div id="member-save-member" class="mt-4 hidden">
        <div class="grid gap-4 lg:grid-cols-[220px_1fr]">
          <div>
            <label for="member-save-select" class="text-xs font-bold uppercase tracking-widest text-slate-300">Trạng thái</label>
            <select id="member-save-select" class="mt-2 w-full rounded-md border border-white/15 bg-[var(--rr-dark-soft)] px-3 py-2 text-sm text-white">
              {savedRepoStatuses.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
            <button
              id="member-save-button"
              type="button"
              class="mt-3 w-full rounded-md bg-white px-3 py-2 text-sm font-semibold text-[var(--rr-dark)] hover:bg-slate-100"
            >
              Lưu vào shortlist
            </button>
          </div>

          <div>
            <label for="member-save-note" class="text-xs font-bold uppercase tracking-widest text-slate-300">Note riêng</label>
            <textarea
              id="member-save-note"
              class="mt-2 min-h-[112px] w-full rounded-md border border-white/15 bg-[var(--rr-dark-soft)] px-3 py-2 text-sm leading-6 text-white placeholder:text-slate-400"
              maxlength="1000"
              placeholder="Ví dụ: test cho client mỹ phẩm, cần GPU, kiểm tra OAuth trước khi giao cho team."
            ></textarea>
            <div class="mt-3 flex flex-wrap gap-2">
              <button
                id="member-note-button"
                type="button"
                class="rounded-md border border-white/20 px-3 py-2 text-sm font-semibold text-white hover:border-white/40 hover:bg-white/10"
              >
                Lưu note
              </button>
              <button
                id="member-unsave-button"
                type="button"
                class="rounded-md border border-amber-300/25 px-3 py-2 text-sm font-semibold text-amber-100 hover:border-amber-300/45 hover:bg-amber-400/10"
              >
                Bỏ lưu repo
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script define:vars={{ repoSlug, repoLoginUrl, savedRepoStatuses }}>
    const memberLock = document.querySelector('#member-lock');
    const memberGuide = document.querySelector('#member-guide');
    const memberSaveGuest = document.querySelector('#member-save-guest');
    const memberSaveMember = document.querySelector('#member-save-member');
    const memberSaveStatus = document.querySelector('#member-save-status');
    const memberSaveSelect = document.querySelector('#member-save-select');
    const memberSaveButton = document.querySelector('#member-save-button');
    const memberNoteButton = document.querySelector('#member-note-button');
    const memberUnsaveButton = document.querySelector('#member-unsave-button');
    const memberSaveNote = document.querySelector('#member-save-note');
    const statusMeta = Object.fromEntries(savedRepoStatuses.map((item) => [item.value, item.label]));
    let savedState = null;

    boot();

    async function boot() {
      await Promise.all([loadMemberGuide(), loadSavedRepoState()]);
    }

    async function loadMemberGuide() {
      try {
        const response = await fetch(`/api/member/repos/${encodeURIComponent(repoSlug)}`, {
          credentials: 'include',
        });
        if (!response.ok) return;

        const payload = await response.json();
        const guide = payload.repo?.practitionerGuide;
        if (!guide) return;

        renderMemberGuide(payload.repo.name, guide);
        memberLock?.classList.add('hidden');
        memberGuide?.classList.remove('hidden');
      } catch {
        // Static preview and logged-out visitors keep the locked teaser.
      }
    }

    async function loadSavedRepoState() {
      try {
        const response = await fetch(`/api/member/saved-repos/${encodeURIComponent(repoSlug)}`, {
          credentials: 'include',
        });

        if (response.status === 401) {
          renderGuestSaveState();
          return;
        }
        if (!response.ok) {
          setSaveStatus('Không đọc được trạng thái shortlist lúc này.');
          return;
        }

        const payload = await response.json();
        savedState = payload.item || null;
        renderMemberSaveState(savedState);
      } catch {
        setSaveStatus('Không đọc được trạng thái shortlist lúc này.');
      }
    }

    memberSaveButton?.addEventListener('click', async () => {
      const select = memberSaveSelect;
      if (!(select instanceof HTMLSelectElement)) return;
      await saveRepo({ status: select.value });
    });

    memberNoteButton?.addEventListener('click', async () => {
      const note = memberSaveNote;
      if (!(note instanceof HTMLTextAreaElement)) return;
      await patchSavedRepo({ note: note.value });
    });

    memberSaveSelect?.addEventListener('change', async () => {
      if (!savedState) return;
      const select = memberSaveSelect;
      if (!(select instanceof HTMLSelectElement)) return;
      await patchSavedRepo({ status: select.value });
    });

    memberUnsaveButton?.addEventListener('click', async () => {
      if (!savedState) return;
      setSaveControlsBusy(true);
      try {
        const response = await fetch(`/api/member/saved-repos/${encodeURIComponent(repoSlug)}`, {
          method: 'DELETE',
          credentials: 'include',
        });
        if (!response.ok) {
          setSaveStatus('Không bỏ lưu được repo này lúc này.');
          return;
        }

        savedState = null;
        renderMemberSaveState(null);
        setSaveStatus('Đã bỏ repo khỏi shortlist của bạn.');
      } catch {
        setSaveStatus('Không bỏ lưu được repo này lúc này.');
      } finally {
        setSaveControlsBusy(false);
      }
    });

    async function saveRepo(body) {
      setSaveControlsBusy(true);
      try {
        const response = await fetch(`/api/member/saved-repos/${encodeURIComponent(repoSlug)}`, {
          method: 'PUT',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body || {}),
        });
        if (!response.ok) {
          setSaveStatus('Không lưu được repo này lúc này.');
          return;
        }

        const payload = await response.json();
        savedState = payload.item || null;
        renderMemberSaveState(savedState);
        setSaveStatus(`Đã lưu repo ở trạng thái ${statusMeta[savedState?.status] || 'đã chọn'}.`);
      } catch {
        setSaveStatus('Không lưu được repo này lúc này.');
      } finally {
        setSaveControlsBusy(false);
      }
    }

    async function patchSavedRepo(body) {
      setSaveControlsBusy(true);
      try {
        const response = await fetch(`/api/member/saved-repos/${encodeURIComponent(repoSlug)}`, {
          method: 'PATCH',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (!response.ok) {
          setSaveStatus('Không cập nhật được shortlist lúc này.');
          return;
        }

        const payload = await response.json();
        savedState = payload.item || null;
        renderMemberSaveState(savedState);
        setSaveStatus('Đã cập nhật shortlist của bạn.');
      } catch {
        setSaveStatus('Không cập nhật được shortlist lúc này.');
      } finally {
        setSaveControlsBusy(false);
      }
    }

    function renderGuestSaveState() {
      memberSaveGuest?.classList.remove('hidden');
      memberSaveMember?.classList.add('hidden');
      setSaveStatus('Đăng nhập để lưu repo, thêm note riêng và quay lại guide khi cần thử thật.');
    }

    function renderMemberSaveState(item) {
      memberSaveGuest?.classList.add('hidden');
      memberSaveMember?.classList.remove('hidden');

      if (memberSaveSelect instanceof HTMLSelectElement) {
        memberSaveSelect.value = item?.status || savedRepoStatuses[0]?.value || 'want_to_try';
      }

      if (memberSaveNote instanceof HTMLTextAreaElement) {
        memberSaveNote.value = item?.note || '';
      }

      if (memberSaveButton instanceof HTMLButtonElement) {
        memberSaveButton.textContent = item ? 'Lưu lại trạng thái' : 'Lưu vào shortlist';
      }

      setSaveStatus(
        item
          ? `Repo này đang ở trạng thái ${statusMeta[item.status] || item.status}. Bạn có thể đổi trạng thái hoặc để lại note riêng.`
          : 'Bạn đã đăng nhập. Chọn trạng thái mặc định rồi lưu repo này vào shortlist của mình.',
      );
    }

    function renderMemberGuide(repoName, guide) {
      setText('#member-guide-title', `Guide thực hành cho ${repoName}`);
      setText('#member-guide-outcome', guide.outcome || 'Guide này đang được hoàn thiện.');
      setText('#member-guide-expected', guide.expectedResult || 'Sau khi thử, bạn có đủ tín hiệu để quyết định có đưa tool vào workflow thật không.');

      renderList('#member-guide-prerequisites', guide.prerequisites || []);
      renderList('#member-guide-steps', guide.steps || [], true);
      renderList('#member-guide-pitfalls', guide.commonPitfalls || []);
    }

    function renderList(selector, items, ordered = false) {
      const root = document.querySelector(selector);
      if (!root) return;
      root.replaceChildren();

      const list = Array.isArray(items) && items.length > 0 ? items : ['Chưa có ghi chú chi tiết cho mục này.'];
      list.forEach((item, index) => {
        const li = document.createElement('li');
        li.className = ordered ? 'flex gap-3' : 'list-disc ml-4';

        if (ordered) {
          const marker = document.createElement('span');
          marker.className = 'mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded bg-white/10 text-xs font-bold text-white';
          marker.textContent = String(index + 1);
          const text = document.createElement('span');
          text.textContent = item;
          li.append(marker, text);
        } else {
          li.textContent = item;
        }

        root.append(li);
      });
    }

    function setSaveControlsBusy(isBusy) {
      [memberSaveSelect, memberSaveButton, memberNoteButton, memberUnsaveButton].forEach((element) => {
        if (element instanceof HTMLButtonElement || element instanceof HTMLSelectElement) {
          element.disabled = isBusy;
        }
      });
    }

    function setText(selector, value) {
      const node = document.querySelector(selector);
      if (node) node.textContent = value;
    }

    function setSaveStatus(message) {
      if (memberSaveStatus) memberSaveStatus.textContent = message;
    }
  </script>

  {related.length > 0 && (
    <section class="mt-8">
      <div class="mb-4">
        <p class="text-xs font-bold uppercase tracking-widest text-[var(--rr-muted)]">Related alternatives</p>
        <h2 class="mt-1 text-2xl font-semibold">Cùng ngành hoặc cùng workflow</h2>
      </div>
      <div class="flex flex-col gap-3">
        {related.map((rel) => (
          <RepoListItem entry={rel} />
        ))}
      </div>
    </section>
  )}

  {showInternalAnalysis && (
    <details class="mt-10 rounded-lg border border-dashed border-[var(--rr-border-strong)] bg-white p-5">
      <summary class="cursor-pointer text-xs font-bold uppercase tracking-widest text-[var(--rr-muted)]">
        Internal analysis and source notes
      </summary>
      <div class="mt-5 space-y-5">
        <div class="rounded-md border border-[var(--rr-warn)]/35 bg-[var(--rr-warn)]/10 p-4">
          <p class="text-sm font-semibold text-amber-700">Vietnam market notes</p>
          <p class="mt-2 text-sm leading-6">{r.vnMarket.insight}</p>
          {r.vnMarket.seoKeywords.length > 0 && <p class="mt-2 text-xs text-[var(--rr-muted)]">SEO keywords: {r.vnMarket.seoKeywords.join(', ')}</p>}
          {r.vnMarket.notes && <p class="mt-1 text-xs text-[var(--rr-muted)]">{r.vnMarket.notes}</p>}
        </div>

        {r.signalSources.length > 0 && (
          <div>
            <p class="text-sm font-semibold">Signal sources</p>
            <ul class="mt-2 flex flex-wrap gap-2">
              {r.signalSources.map((s) => (
                <li>
                  <a href={s.url} target="_blank" rel="nofollow noopener noreferrer" class="rounded-md border border-[var(--rr-border)] px-2.5 py-1 text-xs font-medium hover:border-[var(--rr-core)]">
                    {s.label} ↗
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="max-w-none border-t border-[var(--rr-border)] pt-5 text-sm leading-relaxed text-[var(--rr-text)] [&_blockquote]:border-l-2 [&_blockquote]:border-[var(--rr-border)] [&_blockquote]:pl-3 [&_blockquote]:text-[var(--rr-muted)] [&_h2]:mt-4 [&_h2]:font-semibold [&_li]:ml-4 [&_li]:list-disc [&_p]:mt-3">
          <Content />
        </div>
      </div>
    </details>
  )}
</BaseLayout>
