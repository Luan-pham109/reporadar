---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Member area | AltStack" description="Đăng nhập AltStack để lưu repo, xây shortlist cá nhân và mở practitioner guide theo từng tool.">
  <section class="grid gap-6 lg:grid-cols-[1fr_0.9fr] lg:items-start">
    <div class="overflow-hidden rounded-lg border border-[var(--rr-dark)] bg-[var(--rr-dark)] text-white shadow-[var(--rr-shadow)]">
      <div class="p-6 sm:p-8">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-200">AltStack Member</p>
        <h1 class="mt-3 text-4xl font-bold tracking-tight">Biến radar thành shortlist làm việc của bạn.</h1>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">
          Public brief giúp bạn biết tool có đáng mở tab không. Member area giúp bạn đi thêm một bước:
          lưu repo, đánh dấu trạng thái test, để lại note riêng, rồi mở practitioner guide đúng lúc cần thử thật.
        </p>
      </div>
      <div class="grid gap-0 border-t border-white/10 sm:grid-cols-3">
        <div class="border-b border-white/10 p-4 sm:border-b-0 sm:border-r">
          <p class="font-display text-2xl font-bold text-green-300">Save</p>
          <p class="mt-1 text-xs leading-5 text-slate-300">Lưu repo vào shortlist thay vì bookmark lẻ.</p>
        </div>
        <div class="border-b border-white/10 p-4 sm:border-b-0 sm:border-r">
          <p class="font-display text-2xl font-bold text-blue-200">Track</p>
          <p class="mt-1 text-xs leading-5 text-slate-300">Muốn thử, Đang test, Theo dõi, Bỏ qua, Đã dùng.</p>
        </div>
        <div class="p-4">
          <p class="font-display text-2xl font-bold text-amber-300">Guide</p>
          <p class="mt-1 text-xs leading-5 text-slate-300">Mở lại từng bước thực hành khi cần chạy thử đúng bài.</p>
        </div>
      </div>
    </div>

    <div class="rounded-lg border border-[var(--rr-border)] bg-white p-5 shadow-[var(--rr-shadow)]">
      <p class="text-xs font-bold uppercase tracking-widest text-[var(--rr-core)]">Google-only sign in</p>
      <h2 class="mt-2 text-2xl font-semibold text-[var(--rr-text)]">Vào member area bằng Google</h2>
      <p class="mt-3 text-sm leading-6 text-[var(--rr-muted)]">
        AltStack hiện giữ một đường đăng nhập duy nhất để member flow gọn hơn và giảm bề mặt tấn công.
        Google lo phần xác minh email, còn account của bạn giữ shortlist và note riêng.
      </p>

      <a
        id="google-login"
        href="/api/auth/google/start"
        class="mt-5 block rounded-md border border-[var(--rr-border)] px-3 py-3 text-center text-sm font-semibold text-[var(--rr-text)] no-underline hover:border-[var(--rr-core)] hover:text-[var(--rr-core)]"
        data-track-event="membership_intent"
        data-track-label="login_google"
        data-track-prop-surface="login"
        data-track-prop-method="google"
      >
        Tiếp tục với Google
      </a>

      <div class="mt-4 rounded-md border border-[var(--rr-border)] bg-[var(--rr-surface-soft)] p-3 text-sm text-[var(--rr-muted)]">
        <p class="font-semibold text-[var(--rr-text)]">Sau khi đăng nhập, bạn có thể:</p>
        <ul class="mt-2 space-y-2 leading-6">
          <li>Lưu repo vào shortlist cá nhân ngay từ trang decision brief.</li>
          <li>Thêm note riêng như client cần test, GPU, OAuth hay risk cần nhớ.</li>
          <li>Mở practitioner guide và quay lại đúng repo khi đã tới lúc thử thật.</li>
        </ul>
      </div>

      <div id="member-actions" class="mt-4 hidden rounded-md border border-[var(--rr-border)] bg-[var(--rr-surface-soft)] p-3 text-sm">
        <p id="member-label" class="text-[var(--rr-muted)]"></p>
        <div class="mt-3 flex flex-wrap gap-2">
          <a id="continue-link" href="/account" class="rounded-md bg-[var(--rr-core)] px-3 py-2 font-semibold text-white no-underline hover:bg-blue-700">
            Mở member area
          </a>
          <a href="/account" class="rounded-md border border-[var(--rr-border)] bg-white px-3 py-2 font-semibold text-[var(--rr-text)] no-underline hover:border-[var(--rr-core)] hover:text-[var(--rr-core)]">
            Xem tài khoản
          </a>
          <button id="logout-button" type="button" class="rounded-md border border-[var(--rr-border)] bg-white px-3 py-2 text-[var(--rr-muted)] hover:text-[var(--rr-text)]">
            Đăng xuất
          </button>
        </div>
      </div>

      <p id="login-status" class="mt-4 text-sm leading-6 text-[var(--rr-muted)]" aria-live="polite">
        Đăng nhập bằng Google để lưu repo, quản lý shortlist, mở account page và các guide bị khóa.
      </p>

      <div class="mt-4 flex flex-wrap gap-2 text-xs font-medium text-[var(--rr-muted)]">
        <a href="/" class="hover:text-[var(--rr-core)]">Quay lại radar</a>
        <span>·</span>
        <a href="/rss.xml" class="hover:text-[var(--rr-core)]">RSS public</a>
      </div>
    </div>
  </section>

  <script>
    const status = document.querySelector('#login-status');
    const googleLogin = document.querySelector('#google-login');
    const memberActions = document.querySelector('#member-actions');
    const memberLabel = document.querySelector('#member-label');
    const logoutButton = document.querySelector('#logout-button');
    const continueLink = document.querySelector('#continue-link');

    const params = new URLSearchParams(window.location.search);
    const returnTo = safeBrowserReturnTo(params.get('returnTo') || '/account');

    if (googleLogin instanceof HTMLAnchorElement) {
      googleLogin.href = `/api/auth/google/start?returnTo=${encodeURIComponent(returnTo)}`;
    }

    if (continueLink instanceof HTMLAnchorElement) {
      continueLink.href = returnTo;
      continueLink.textContent = returnTo === '/account' ? 'Mở member area' : 'Tiếp tục tới nội dung đang mở';
    }

    logoutButton?.addEventListener('click', async () => {
      setBusy(true);
      track('membership_logout_submit', { surface: 'login_page' });
      try {
        await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' });
        showMember(null);
        track('membership_logout_success', { surface: 'login_page' });
        setStatus('Đã đăng xuất. Bạn có thể đăng nhập lại bằng Google bất kỳ lúc nào.');
      } catch {
        setStatus('Không đăng xuất được. Thử tải lại trang rồi làm lại.');
      } finally {
        setBusy(false);
      }
    });

    boot();

    async function boot() {
      try {
        const response = await fetch('/api/auth/me', { credentials: 'include' });
        if (!response.ok) return;
        const payload = await response.json();
        showMember(payload.user || null);
      } catch {
        setStatus('Auth runtime chưa chạy trong preview tĩnh. Dùng `npm run dev:functions` để thử đăng nhập thật.');
      }
    }

    function showMember(user) {
      const loggedIn = Boolean(user);
      memberActions?.classList.toggle('hidden', !loggedIn);

      if (memberLabel) {
        memberLabel.textContent = loggedIn
          ? `Đang đăng nhập: ${user.name || user.email}`
          : '';
      }

      if (googleLogin instanceof HTMLElement) {
        googleLogin.classList.toggle('hidden', loggedIn);
      }

      setStatus(
        loggedIn
          ? 'Phiên đăng nhập đang hoạt động. Bạn có thể vào member area, quay lại repo đã lưu, hoặc tiếp tục tới nội dung đang mở.'
          : 'Đăng nhập bằng Google để lưu repo, quản lý shortlist, mở account page và các guide bị khóa.',
      );
    }

    function setBusy(isBusy) {
      if (logoutButton instanceof HTMLButtonElement) logoutButton.disabled = isBusy;
    }

    function setStatus(message) {
      if (status) status.textContent = message;
    }

    function safeBrowserReturnTo(value) {
      if (!value || !value.startsWith('/') || value.startsWith('//') || /[\r\n]/.test(value) || value.length > 512) {
        return '/account';
      }
      try {
        const path = new URL(value, window.location.origin).pathname.toLowerCase();
        if (path.endsWith('.json') || path.endsWith('.xml')) return '/account';
      } catch {
        return '/account';
      }
      return value;
    }

    function track(name, properties = {}) {
      if (typeof window.altstackTrack === 'function') {
        window.altstackTrack(name, properties);
      }
    }
  </script>
</BaseLayout>
