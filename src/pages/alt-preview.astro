---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FacetFilter from '../components/FacetFilter.astro';
import RepoCardFlat from '../components/RepoCardFlat.astro';
import { includeDraft } from '../lib/drafts';
import { INDUSTRIES } from '../lib/industries';

const entries = (await getCollection('repos', ({ data }) => includeDraft(data))).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const verticalCounts = INDUSTRIES.map((industry) => ({
  value: industry.slug,
  label: industry.short,
  count: entries.filter((entry) => entry.data.vertical.includes(industry.slug)).length,
})).filter((item) => item.count > 0);

const maturityLabel: Record<string, string> = {
  'pre-viral': 'Pre-viral',
  rising: 'Rising',
  established: 'Established',
};

const maturityCounts = ['pre-viral', 'rising', 'established']
  .map((value) => ({
    value,
    label: maturityLabel[value],
    count: entries.filter((entry) => entry.data.maturity === value).length,
  }))
  .filter((item) => item.count > 0);

const tagCounts = [...entries.reduce((counts, entry) => {
  for (const tag of entry.data.tags) counts.set(tag, (counts.get(tag) ?? 0) + 1);
  return counts;
}, new Map<string, number>())]
  .map(([tag, count]) => ({ value: tag.toLowerCase(), label: tag, count }))
  .sort((a, b) => b.count - a.count || a.label.localeCompare(b.label, 'vi'))
  .slice(0, 18);
---

<BaseLayout title="Alt preview | AltStack" description="Bản preview card + grid kiểu OpenAlternative để so A/B trước khi swap vào production.">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <a href="/#radar" class="text-sm font-medium text-[var(--rr-muted)] no-underline hover:text-[var(--rr-core)]">← So với bản hiện tại</a>
    <span class="rounded-full border border-[var(--rr-border)] bg-white px-3 py-1 text-xs font-semibold text-[var(--rr-muted)]">
      Preview route
    </span>
  </div>

  <section class="mt-4 rounded-[var(--rr-radius-lg)] border border-[var(--rr-border)] bg-white p-6 shadow-[var(--rr-shadow-sm)]">
    <p class="text-xs font-bold uppercase tracking-widest text-[var(--rr-core)]">Alt Preview</p>
    <h1 class="mt-2 text-3xl font-semibold text-[var(--rr-text)] sm:text-4xl">Card phẳng để so A/B với homepage hiện tại</h1>
    <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--rr-muted)]">
      Bản này chỉ thử lại card và grid theo hướng OpenAlternative: border hairline, khoảng trắng rộng hơn,
      avatar owner GitHub, stat row rõ ràng và line “Alternative to” để nhìn nhanh hơn ở bề mặt directory.
    </p>
  </section>

  <div class="mt-6">
    <FacetFilter
      facets={{ vertical: verticalCounts, maturity: maturityCounts, tag: tagCounts }}
      basePath="/alt-preview"
      anchorId="alt-preview-grid"
      label="Preview filter"
      description="Lọc thử ngay trên layout preview để kiểm tra card phẳng có vẫn hỗ trợ các luồng duyệt chính hay không."
    />
  </div>

  <section id="alt-preview-grid" class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {entries.map((entry) => (
      <RepoCardFlat entry={entry} />
    ))}
  </section>
</BaseLayout>
