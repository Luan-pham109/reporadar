---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { groupByAlternative } from '../../lib/alternatives';
import { includeDraft } from '../../lib/drafts';

const entries = await getCollection('repos', ({ data }) => includeDraft(data));
const groups = [...groupByAlternative(entries).values()]
  .filter((group) => group.entries.length > 0)
  .sort((a, b) => b.entries.length - a.entries.length || a.name.localeCompare(b.name, 'vi'));

const title = 'Alternatives directory | AltStack';
const description =
  'Danh mục các tool trả phí có repo open-source thay thế trong AltStack, gom theo từng brand để đi nhanh tới lựa chọn phù hợp.';

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: groups.map((group, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: group.name,
    url: `https://altstack.io.vn/alternatives/${group.slug}/`,
  })),
};
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(itemListLd)} />
  </Fragment>

  <a href="/" class="text-sm font-medium text-[var(--rr-muted)] no-underline hover:text-[var(--rr-core)]">← AltStack</a>

  <section class="mt-4 rounded-[var(--rr-radius-lg)] border border-[var(--rr-border)] bg-white p-6 shadow-[var(--rr-shadow-sm)]">
    <p class="text-xs font-bold uppercase tracking-widest text-[var(--rr-core)]">Alternatives</p>
    <h1 class="mt-2 text-3xl font-semibold text-[var(--rr-text)] sm:text-4xl">Tra cứu theo tool bạn đang trả tiền</h1>
    <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--rr-muted)]">
      Mỗi trang gom các repo open-source trong AltStack có thể thay một brand hoặc workflow trả phí cụ thể.
      Từ đây bạn có thể đi thẳng vào nhóm như Runway, Jira hay Buffer thay vì lướt toàn bộ radar.
    </p>
    <div class="mt-5 flex flex-wrap gap-3 text-sm text-[var(--rr-muted)]">
      <span class="rounded-full bg-[var(--rr-surface-soft)] px-3 py-1.5">{groups.length} brand có landing page</span>
      <span class="rounded-full bg-[var(--rr-surface-soft)] px-3 py-1.5">{entries.length} repo trong radar</span>
    </div>
  </section>

  {groups.length === 0 ? (
    <p class="mt-6 rounded-[var(--rr-radius)] border border-[var(--rr-border)] bg-white p-6 text-[var(--rr-muted)]">
      Chưa có dữ liệu alternatives để hiển thị.
    </p>
  ) : (
    <section class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {groups.map((group) => (
        <a
          href={`/alternatives/${group.slug}`}
          class="as-card group rounded-[var(--rr-radius)] p-4 no-underline transition-colors"
        >
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--rr-muted)]">Alternative to</p>
          <h2 class="mt-2 text-lg font-semibold text-[var(--rr-text)] group-hover:text-[var(--rr-core)]">{group.name}</h2>
          <p class="mt-1 text-sm text-[var(--rr-muted)]">{group.entries.length} repo open-source</p>
          <p class="mt-4 text-sm font-semibold text-[var(--rr-core)]">Mở landing page</p>
        </a>
      ))}
    </section>
  )}
</BaseLayout>
