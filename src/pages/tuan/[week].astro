---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RepoCard from '../../components/RepoCard.astro';
import { includeDraft } from '../../lib/drafts';

export async function getStaticPaths() {
  const entries = await getCollection('repos', ({ data }) => includeDraft(data));
  const byWeek = new Map<string, typeof entries>();
  for (const e of entries) {
    const list = byWeek.get(e.data.week) ?? [];
    list.push(e);
    byWeek.set(e.data.week, list);
  }
  return [...byWeek.entries()].map(([week, list]) => ({
    params: { week },
    props: {
      week,
      entries: list.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()),
    },
  }));
}

const { week, entries } = Astro.props;
const replacementCount = entries.filter((entry) => entry.data.paidToolReplaced).length;
const description = `AltStack Weekly ${week}: ${entries.length} công cụ AI/open-source đáng chú ý, ${replacementCount} tool thay được SaaS trả phí — chọn lọc cho creative, agency và ecommerce Việt Nam.`;
---

<BaseLayout title={`AltStack Weekly ${week} - công cụ AI/open-source đáng chú ý`} description={description}>
  <a href="/" class="text-sm font-medium text-[var(--rr-muted)] no-underline hover:text-[var(--rr-core)]">← AltStack</a>

  <header class="mt-4 overflow-hidden rounded-lg border border-[var(--rr-dark)] bg-[var(--rr-dark)] text-white shadow-[var(--rr-shadow)]">
    <div class="grid gap-0 sm:grid-cols-[1.25fr_0.75fr]">
      <div class="p-6 sm:p-8">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-200">AltStack Weekly</p>
        <h1 class="mt-3 text-4xl font-bold tracking-tight">Issue {week}</h1>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">
          Ít công cụ hơn, quyết định rõ hơn. Tuần này chọn các tool có tín hiệu đáng xem,
          kèm góc thay SaaS, workflow impact và cạm bẫy triển khai.
        </p>
      </div>
      <div class="border-t border-white/10 bg-white/[0.04] p-6 sm:border-l sm:border-t-0 sm:p-8">
        <div class="grid grid-cols-2 gap-2">
          <div class="rounded-md border border-white/10 bg-white/10 p-3">
            <p class="font-display text-3xl font-bold">{entries.length}</p>
            <p class="mt-1 text-xs text-slate-300">briefs</p>
          </div>
          <div class="rounded-md border border-white/10 bg-white/10 p-3">
            <p class="font-display text-3xl font-bold text-green-300">{replacementCount}</p>
            <p class="mt-1 text-xs text-slate-300">replacements</p>
          </div>
        </div>
      </div>
    </div>
  </header>

  <section class="mt-8 grid gap-4 lg:grid-cols-2">
    {entries.map((entry) => (
      <RepoCard entry={entry} />
    ))}
  </section>
</BaseLayout>
