---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import RepoListItem from '../components/RepoListItem.astro';
import IndustryNav from '../components/IndustryNav.astro';
import { includeDraft } from '../lib/drafts';

// Feed liên tục: ẩn draft ở production, mới nhất lên đầu (PRD §7).
const entries = (await getCollection('repos', ({ data }) => includeDraft(data))).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

// Gom theo tuần để link sang trang tổng hợp newsletter.
const weeks = [...new Set(entries.map((e) => e.data.week))].sort().reverse();
---

<BaseLayout>
  <section class="mb-7 border-b border-[var(--rr-border)] pb-7">
    <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-[var(--rr-core)]">AI tool radar cho người làm nghề</p>
    <h1 class="max-w-2xl text-3xl font-bold tracking-tight sm:text-4xl">Biết công cụ AI nào đáng thử trước khi nó thành ồn ào.</h1>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-[var(--rr-muted)]">
      RepoRadar VN chọn lọc repo và tool AI cho creative, agency, ecom, SEO. Mỗi bài trả lời nhanh:
      dùng vào việc gì, thay được khâu nào, có đáng thử ở Việt Nam không.
    </p>

    <div class="mt-5 grid gap-3 sm:grid-cols-3">
      <div class="rounded-md border border-[var(--rr-border)] bg-[var(--rr-surface)] p-3">
        <p class="text-sm font-semibold">Săn sớm</p>
        <p class="mt-1 text-xs leading-5 text-[var(--rr-muted)]">Tool có tín hiệu tốt trước khi quá đông người viết lại.</p>
      </div>
      <div class="rounded-md border border-[var(--rr-border)] bg-[var(--rr-surface)] p-3">
        <p class="text-sm font-semibold">Dùng được</p>
        <p class="mt-1 text-xs leading-5 text-[var(--rr-muted)]">Không chỉ “hay ho”: phải cắt được việc thật cho team/shop/agency.</p>
      </div>
      <div class="rounded-md border border-[var(--rr-border)] bg-[var(--rr-surface)] p-3">
        <p class="text-sm font-semibold">Hợp bối cảnh Việt Nam</p>
        <p class="mt-1 text-xs leading-5 text-[var(--rr-muted)]">Có góc nhìn về chi phí, thói quen dùng tool và rào cản triển khai.</p>
      </div>
    </div>

    <div class="mt-5 flex flex-wrap gap-2">
      <a href="#radar" class="rounded-md bg-[var(--rr-core)] px-3 py-2 text-sm font-semibold text-black no-underline hover:opacity-90">
        Xem radar tuần này
      </a>
      <a href="/rss.xml" class="rounded-md border border-[var(--rr-border)] px-3 py-2 text-sm text-[var(--rr-muted)] no-underline hover:border-[var(--rr-core)]/50 hover:text-[var(--rr-text)]">
        Theo dõi RSS
      </a>
      <a href="/feed.json" class="rounded-md border border-[var(--rr-border)] px-3 py-2 text-sm text-[var(--rr-muted)] no-underline hover:border-[var(--rr-core)]/50 hover:text-[var(--rr-text)]">
        JSON feed
      </a>
    </div>
  </section>

  <section class="mb-7">
    <div class="mb-2 flex flex-wrap items-baseline justify-between gap-2">
      <h2 class="text-sm font-semibold">Duyệt theo ngành</h2>
      <p class="text-xs text-[var(--rr-muted)]">Creative, agency, ecom, SEO</p>
    </div>
    <IndustryNav />
  </section>

  <section id="radar" class="mb-8 scroll-mt-20">
    <div class="mb-3 flex flex-wrap items-end justify-between gap-2">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--rr-muted)]">Radar mới nhất</p>
        <h2 class="mt-1 text-xl font-semibold">Công cụ đáng mở tab hôm nay</h2>
      </div>
      {weeks.length > 0 && (
        <div class="flex flex-wrap gap-2 text-xs">
          <span class="text-[var(--rr-muted)]">Tổng hợp tuần:</span>
          {weeks.map((w) => (
            <a href={`/tuan/${w}`} class="rounded border border-[var(--rr-border)] px-2 py-0.5 hover:border-[var(--rr-core)]/50">
              {w}
            </a>
          ))}
        </div>
      )}
    </div>

    {entries.length === 0 ? (
      <p class="text-[var(--rr-muted)]">Chưa có công cụ nào được đăng.</p>
    ) : (
      <div class="flex flex-col gap-2">
        {entries.map((entry) => (
          <RepoListItem entry={entry} />
        ))}
      </div>
    )}
  </section>

  <section class="rounded-md border border-[var(--rr-border)] bg-[var(--rr-surface)] p-4">
    <div class="grid gap-4 sm:grid-cols-[1.3fr_1fr] sm:items-center">
      <div>
        <h2 class="text-base font-semibold">Muốn nhận bản radar đều hơn?</h2>
        <p class="mt-1 text-sm leading-6 text-[var(--rr-muted)]">
          Mục tiêu tiếp theo là gửi digest ngắn: vài tool đáng thử, góc dùng ở Việt Nam, và cảnh báo cạm bẫy trước khi bạn mất thời gian test.
        </p>
      </div>
      <div class="flex flex-wrap gap-2 sm:justify-end">
        <a href="/rss.xml" class="rounded-md bg-[var(--rr-core)] px-3 py-2 text-sm font-semibold text-black no-underline hover:opacity-90">RSS trước</a>
        <a href="/feed.json" class="rounded-md border border-[var(--rr-border)] px-3 py-2 text-sm text-[var(--rr-muted)] no-underline hover:border-[var(--rr-core)]/50 hover:text-[var(--rr-text)]">JSON feed</a>
      </div>
    </div>
  </section>
</BaseLayout>
