---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import RepoListItem from '../components/RepoListItem.astro';
import IndustryNav from '../components/IndustryNav.astro';
import TagFilter from '../components/TagFilter.astro';
import { includeDraft } from '../lib/drafts';

const entries = (await getCollection('repos', ({ data }) => includeDraft(data))).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const weeks = [...new Set(entries.map((e) => e.data.week))].sort().reverse();
const latestWeek = weeks[0];
const replacementCount = entries.filter((e) => e.data.paidToolReplaced).length;
const preViralCount = entries.filter((e) => e.data.maturity === 'pre-viral').length;
const tagCounts = [...entries.reduce((counts, entry) => {
  for (const tag of entry.data.tags) counts.set(tag, (counts.get(tag) ?? 0) + 1);
  return counts;
}, new Map<string, number>())]
  .map(([tag, count]) => ({ tag, count }))
  .sort((a, b) => b.count - a.count || a.tag.localeCompare(b.tag));
---

<BaseLayout>
  <section class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-end">
    <div>
      <p class="mb-3 text-xs font-bold uppercase tracking-widest text-[var(--rr-core)]">Open-source alternatives for expensive software</p>
      <h1 class="max-w-3xl text-4xl font-bold tracking-tight text-[var(--rr-text)] sm:text-5xl lg:text-6xl">
        Trước khi gia hạn SaaS, kiểm tra AltStack.
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-7 text-[var(--rr-muted)]">
        AltStack chọn lọc công cụ AI/open-source giúp team Việt Nam biết tool nào thay được phần mềm đắt tiền,
        cắt được khâu nào, khó triển khai không và có đáng thử trong công việc thật không.
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href="#radar" class="rounded-md bg-[var(--rr-core)] px-4 py-2.5 text-sm font-semibold !text-white no-underline shadow-sm hover:bg-blue-700">
          Xem radar mới nhất
        </a>
        <a href="#stacks" class="rounded-md border border-[var(--rr-border-strong)] bg-white px-4 py-2.5 text-sm font-semibold text-[var(--rr-text)] no-underline hover:border-[var(--rr-core)] hover:text-[var(--rr-core)]">
          Duyệt theo workflow
        </a>
      </div>
    </div>

    <div class="overflow-hidden rounded-lg border border-[var(--rr-dark)] bg-[var(--rr-dark)] text-white shadow-[var(--rr-shadow)]">
      <div class="border-b border-white/10 p-4">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-200">Radar console</p>
        <p class="mt-2 font-display text-3xl font-bold">Replace the stack. Keep the capability.</p>
      </div>
      <div class="p-4">
      <div class="mb-3 flex items-center justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase text-slate-400">Decision system</p>
          <p class="mt-1 font-display text-xl font-bold">Try / Watch / Skip</p>
        </div>
        <span class="rounded-md bg-white/10 px-2.5 py-1 text-xs font-semibold text-slate-200">{entries.length} briefs</span>
      </div>
      <div class="grid gap-2 text-sm">
        <div class="rounded-md border border-white/10 bg-white/10 p-3">
          <p class="font-semibold text-green-300">Replaces</p>
          <p class="mt-1 text-slate-300">{replacementCount} tool có ghi rõ SaaS/phần mềm có thể thay.</p>
        </div>
        <div class="rounded-md border border-white/10 bg-white/10 p-3">
          <p class="font-semibold text-white">Workflow impact</p>
          <p class="mt-1 text-slate-300">Ưu tiên brief nói được khâu nào được cắt, tiết kiệm gì, ai không nên dùng.</p>
        </div>
        <div class="rounded-md border border-blue-300/20 bg-blue-400/10 p-3">
          <p class="font-semibold text-blue-200">Pre-viral signal</p>
          <p class="mt-1 text-slate-300">{preViralCount} tín hiệu sớm để theo dõi trước khi thị trường viết lại quá nhiều.</p>
        </div>
      </div>
      </div>
    </div>
  </section>

  <section id="stacks" class="mt-10 scroll-mt-24 rounded-lg border border-[var(--rr-border)] bg-white p-5">
    <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-[var(--rr-muted)]">Stacks</p>
        <h2 class="mt-1 text-2xl font-semibold">Duyệt theo đội đang ra quyết định</h2>
      </div>
      <p class="max-w-md text-sm leading-6 text-[var(--rr-muted)]">Creative, agency, ecommerce và SEO cần câu hỏi khác nhau trước khi đưa một tool vào workflow.</p>
    </div>
    <IndustryNav />
  </section>

  <section id="radar" class="mt-10 scroll-mt-24">
    <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-[var(--rr-muted)]">AltStack Radar</p>
        <h2 class="mt-1 text-2xl font-semibold">Công cụ đáng mở tab hôm nay</h2>
      </div>
      {latestWeek && (
        <a href={`/tuan/${latestWeek}`} class="rounded-md border border-[var(--rr-border)] bg-white px-3 py-2 text-sm font-semibold text-[var(--rr-text)] no-underline hover:border-[var(--rr-core)] hover:text-[var(--rr-core)]">
          Weekly {latestWeek}
        </a>
      )}
    </div>

    <div class="mb-4">
      <TagFilter
        tags={tagCounts}
        basePath="/"
        label="Find by tag"
        description="Lọc nhanh theo use case, category hoặc workflow để tìm repo phù hợp hơn."
      />
    </div>

    {entries.length === 0 ? (
      <p class="rounded-lg border border-[var(--rr-border)] bg-white p-5 text-[var(--rr-muted)]">Chưa có công cụ nào được đăng.</p>
    ) : (
      <div class="flex flex-col gap-3">
        {entries.map((entry) => (
          <RepoListItem entry={entry} />
        ))}
      </div>
    )}
  </section>

  <section id="weekly" class="mt-10 scroll-mt-24 rounded-lg border border-[var(--rr-dark)] bg-[var(--rr-dark)] p-5 text-white">
    <div class="grid gap-5 sm:grid-cols-[1.3fr_1fr] sm:items-center">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-blue-200">AltStack Weekly</p>
        <h2 class="mt-2 text-xl font-semibold">Ít tool hơn, quyết định rõ hơn.</h2>
        <p class="mt-2 text-sm leading-6 text-slate-300">
          Digest ngắn cho vài công cụ đáng thử, góc dùng ở Việt Nam và cảnh báo cạm bẫy trước khi bạn mất thời gian test.
        </p>
      </div>
      <div class="flex flex-wrap gap-2 sm:justify-end">
        <a href="/rss.xml" class="rounded-md bg-white px-3 py-2 text-sm font-semibold text-[var(--rr-dark)] no-underline hover:bg-slate-100">Theo dõi RSS</a>
        <a
          href="/login"
          class="rounded-md border border-white/40 px-3 py-2 text-sm font-semibold text-white no-underline hover:border-white/60 hover:bg-white/10"
          data-track-event="membership_intent"
          data-track-label="homepage_weekly_member_insight"
          data-track-prop-surface="homepage_weekly"
        >
          Member insight
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
